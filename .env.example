# --- News API (GNews.io) ---
# Get a free key at https://gnews.io/  (free tier: 100 requests/day)
GNEWS_API_KEY=

# --- GenAI (OpenAI) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- MongoDB ---
# A MongoDB Atlas connection string, e.g.
# mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Optional: database name (defaults to smart_reviewer)
MONGODB_DB=smart_reviewer

# --- Rate limiting (OPTIONAL: Upstash Redis) ---
# If unset, rate limiting is disabled (the app still runs). Provision a free
# Upstash Redis (e.g. via the Vercel Marketplace) to enable per-IP limits on
# /api/analyze and /api/news.
#
# The Vercel Marketplace integration usually creates KV_* names:
KV_REST_API_URL=
KV_REST_API_TOKEN=
#
# Direct Upstash setup may use these names instead:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
